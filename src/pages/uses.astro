---
import Layout from '../layouts/Layout.astro';
import Nav from '../components/Nav.astro';
import Footer from '../components/Footer.astro';
import PageHero from '../components/PageHero.astro';
import { profile } from '../data/profile';
---

<Layout title="Uses — Mahfuzur Rahman" description="Tools, workflow, and setup used by Mahfuzur Rahman.">
  <Nav />
  <main class="pb-18 pt-8 md:pb-28 md:pt-12">
    <div class="mx-auto w-[min(1180px,calc(100%-1.5rem))] space-y-8 md:w-[min(1180px,calc(100%-2rem))]">
      <PageHero eyebrow="Uses" title="Tools and workflow" description="A practical overview of the tools, stack, and working style behind the portfolio and day-to-day engineering work." />

      <div class="grid gap-5 md:grid-cols-2">
        {profile.skillGroups.map((group) => (
          <section class="panel rounded-[30px] p-6 md:p-8">
            <p class="eyebrow mb-4 text-xs font-semibold text-brand-aqua/80">{group.title}</p>
            <div class="flex flex-wrap gap-2">
              {group.items.map((item) => (
                <span class="rounded-full border border-white/10 bg-white/5 px-3 py-2 text-sm text-white/82">{item}</span>
              ))}
            </div>
          </section>
        ))}
      </div>

      <section class="panel rounded-[32px] p-6 md:p-8">
        <h2 class="text-2xl font-semibold text-white">Operating preferences</h2>
        <div class="mt-6 grid gap-4 md:grid-cols-3">
          <div class="rounded-[24px] border border-white/10 bg-white/5 p-4 text-sm leading-7 text-brand-muted">Prefer clear architecture over abstraction for abstraction’s sake.</div>
          <div class="rounded-[24px] border border-white/10 bg-white/5 p-4 text-sm leading-7 text-brand-muted">Enjoy shipping product improvements that are measurable in speed, maintainability, or user experience.</div>
          <div class="rounded-[24px] border border-white/10 bg-white/5 p-4 text-sm leading-7 text-brand-muted">Like workflows that reduce release friction: Docker, CI/CD, automation, and predictable deploy paths.</div>
        </div>
      </section>
    </div>
  </main>
  <Footer />
</Layout>
