---
import Layout from '../../layouts/Layout.astro';
import Nav from '../../components/Nav.astro';
import Footer from '../../components/Footer.astro';
import { projects } from '../../data/projects';

export function getStaticPaths() {
  return projects.map((project) => ({
    params: { slug: project.slug },
    props: { project },
  }));
}

const { project } = Astro.props;
---

<Layout title={`${project.title} — Mahfuzur Rahman`} description={project.tagline}>
  <Nav />
  <main class="pb-18 pt-8 md:pb-28 md:pt-12">
    <div class="mx-auto w-[min(980px,calc(100%-1.5rem))] space-y-8 md:w-[min(980px,calc(100%-2rem))]">
      <section class="panel rounded-[36px] p-6 md:p-10">
        <p class="eyebrow mb-4 text-xs font-semibold text-brand-aqua/80">{project.category}</p>
        <h1 class="text-4xl font-semibold tracking-[-0.06em] text-white md:text-6xl md:leading-[0.95]">{project.title}</h1>
        <p class="mt-5 text-base leading-8 text-brand-muted md:text-lg">{project.tagline}</p>
        <div class="mt-8 flex flex-wrap gap-2">
          <span class="rounded-full border border-white/10 bg-white/5 px-3 py-2 text-sm text-white/82">{project.period}</span>
          <span class="rounded-full border border-white/10 bg-white/5 px-3 py-2 text-sm text-white/82">{project.role}</span>
          {project.stack.map((item) => (
            <span class="rounded-full border border-white/10 bg-white/5 px-3 py-2 text-sm text-white/82">{item}</span>
          ))}
        </div>
      </section>

      <section class="grid gap-5 md:grid-cols-2">
        <article class="panel rounded-[30px] p-6 md:p-8">
          <p class="eyebrow mb-4 text-xs font-semibold text-brand-pink/80">Impact</p>
          <p class="text-base leading-8 text-brand-muted">{project.impact}</p>
        </article>
        <article class="panel rounded-[30px] p-6 md:p-8">
          <p class="eyebrow mb-4 text-xs font-semibold text-brand-gold/80">Challenge</p>
          <p class="text-base leading-8 text-brand-muted">{project.challenge}</p>
        </article>
      </section>

      <section class="panel rounded-[32px] p-6 md:p-8">
        <h2 class="text-2xl font-semibold text-white">What I did</h2>
        <ul class="mt-6 space-y-4 text-sm leading-7 text-brand-muted md:text-base">
          {project.solution.map((item) => (
            <li class="flex gap-3"><span class="mt-2 h-1.5 w-1.5 rounded-full bg-brand-aqua"></span><span>{item}</span></li>
          ))}
        </ul>
      </section>

      <section class="panel rounded-[32px] p-6 md:p-8">
        <h2 class="text-2xl font-semibold text-white">Outcomes</h2>
        <div class="mt-6 grid gap-4 md:grid-cols-3">
          {project.outcomes.map((item) => (
            <div class="rounded-[24px] border border-white/10 bg-white/5 p-4 text-sm leading-7 text-white/82">{item}</div>
          ))}
        </div>
      </section>

      <div class="flex flex-wrap gap-4">
        <a href="/projects" class="text-sm font-semibold text-white transition hover:text-brand-aqua">← Back to projects</a>
        <a href="/contact" class="text-sm font-semibold text-white transition hover:text-brand-aqua">Discuss a build →</a>
      </div>
    </div>
  </main>
  <Footer />
</Layout>
