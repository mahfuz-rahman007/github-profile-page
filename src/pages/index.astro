---
import Layout from '../layouts/Layout.astro';
import Nav from '../components/Nav.astro';
import SectionHeading from '../components/SectionHeading.astro';

const featuredProjects = [
  {
    title: 'xCloud engineering',
    description: 'Production-focused engineering work across full-stack behavior, practical feature delivery, and systems that survive real users instead of demo-day optimism.',
    tags: ['Laravel', 'Vue / Nuxt', 'Product delivery'],
  },
  {
    title: 'Infrastructure-aware builds',
    description: 'Zero-downtime deployments, VPS workflows, Dockerized services, CI/CD, caching, and backend architecture that cares what happens after launch.',
    tags: ['Docker', 'GitHub Actions', 'AWS / VPS'],
  },
  {
    title: 'Writing that explains systems',
    description: 'Technical articles around Laravel internals, asynchronous jobs, MySQL search, deployment flow, and the engineering decisions under the hood.',
    tags: ['DEV articles', 'Laravel', 'Systems thinking'],
  },
];

const journeySteps = [
  {
    label: 'Now',
    title: 'Building the premium portfolio layer',
    text: 'Astro foundation, cinematic motion, content architecture, and a frontend experience that feels more like a guided journey than a flat portfolio page.',
  },
  {
    label: 'Proof',
    title: 'Shipping real full-stack work',
    text: 'From backend systems to polished interfaces, the goal is not just aesthetics — it is credibility through real implementation depth.',
  },
  {
    label: 'Next',
    title: 'Projects, blog, and detailed case studies',
    text: 'This evolves into a multi-page application with project deep-dives, writing, and a stronger personal-brand system over time.',
  },
];

const articleHighlights = [
  'How Laravel handles queue jobs asynchronously in a single-threaded language',
  'Exploring MySQL full-text search in Laravel',
  'Docker multi-container deployment with GitHub Actions',
];
---

<Layout>
  <a id="top"></a>
  <Nav />

  <main>
    <section class="relative overflow-hidden pb-16 pt-8 md:pb-24 md:pt-12">
      <div class="noise"></div>
      <div class="hero-orb orb-a"></div>
      <div class="hero-orb orb-b"></div>
      <div class="hero-orb orb-c"></div>

      <div class="mx-auto grid w-[min(1180px,calc(100%-1.5rem))] gap-6 md:w-[min(1180px,calc(100%-2rem))] md:grid-cols-[1.25fr_0.9fr] md:items-stretch">
        <div class="panel glass-line section-glow relative overflow-hidden rounded-[32px] p-7 md:p-10">
          <div class="absolute inset-0 bg-[radial-gradient(circle_at_top_right,rgba(124,156,255,0.18),transparent_30%),radial-gradient(circle_at_bottom_left,rgba(111,255,233,0.08),transparent_24%)]"></div>
          <div class="relative">
            <p class="eyebrow mb-5 text-xs font-semibold text-brand-aqua/80">Full-stack engineer • systems-minded builder • product taste</p>
            <h1 class="max-w-4xl text-5xl font-semibold tracking-[-0.06em] text-white md:text-7xl md:leading-[0.94]">
              Make every section feel like the user just stepped into a better internet.
            </h1>
            <p class="mt-6 max-w-2xl text-base leading-8 text-brand-muted md:text-lg">
              Mahfuzur Rahman builds practical systems, polished interfaces, and production-grade experiences. This portfolio is evolving into an immersive frontend application — fast, cinematic, and engineered to leave an impression.
            </p>

            <div class="mt-8 flex flex-wrap gap-3">
              <a href="#projects" class="shine rounded-full bg-white px-5 py-3 text-sm font-semibold text-slate-950 transition hover:translate-y-[-1px]">Explore the build journey</a>
              <a href="#writing" class="rounded-full border border-white/10 bg-white/5 px-5 py-3 text-sm font-medium text-white/85 transition hover:border-white/25 hover:bg-white/8">Read engineering notes</a>
            </div>

            <div class="mt-10 grid gap-4 sm:grid-cols-3">
              <div class="rounded-3xl border border-white/10 bg-white/5 p-4">
                <p class="text-3xl font-semibold text-white">16+</p>
                <p class="mt-2 text-sm text-brand-muted">Published DEV posts turning systems work into readable engineering knowledge.</p>
              </div>
              <div class="rounded-3xl border border-white/10 bg-white/5 p-4">
                <p class="text-3xl font-semibold text-white">Full-stack</p>
                <p class="mt-2 text-sm text-brand-muted">Laravel, React, Vue, Nuxt, Node, Docker, AWS, Redis, PostgreSQL and more.</p>
              </div>
              <div class="rounded-3xl border border-white/10 bg-white/5 p-4">
                <p class="text-3xl font-semibold text-white">Fast-first</p>
                <p class="mt-2 text-sm text-brand-muted">Immersive motion, yes — but only the kind that respects performance and attention.</p>
              </div>
            </div>
          </div>
        </div>

        <div class="panel rounded-[32px] p-6 md:p-8">
          <div class="flex h-full flex-col justify-between gap-6">
            <div>
              <p class="eyebrow text-xs font-semibold text-brand-pink/80">Experience map</p>
              <h2 class="mt-3 text-2xl font-semibold text-white md:text-3xl">A smoother, deeper portfolio is now the mission.</h2>
            </div>

            <div class="story-line space-y-5 rounded-[28px] border border-white/10 bg-white/5 p-5">
              {journeySteps.map((step) => (
                <div class="relative pl-8">
                  <span class="absolute left-[0.3rem] top-1 h-3 w-3 rounded-full bg-brand-accent shadow-[0_0_24px_rgba(124,156,255,0.9)]"></span>
                  <p class="text-xs font-semibold uppercase tracking-[0.2em] text-brand-aqua/80">{step.label}</p>
                  <h3 class="mt-1 text-lg font-semibold text-white">{step.title}</h3>
                  <p class="mt-2 text-sm leading-7 text-brand-muted">{step.text}</p>
                </div>
              ))}
            </div>

            <div class="rounded-[28px] border border-white/10 bg-slate-950/60 p-5">
              <p class="text-xs font-semibold uppercase tracking-[0.2em] text-white/50">Current focus</p>
              <p class="mt-3 text-sm leading-7 text-brand-muted">Astro foundation, premium motion system, projects/blog architecture, GitHub Pages-safe deployment, and a homepage that makes visitors stay instead of politely escaping.</p>
            </div>
          </div>
        </div>
      </div>
    </section>

    <section id="journey" class="pb-8 pt-8 md:pb-12">
      <div class="mx-auto w-[min(1180px,calc(100%-1.5rem))] md:w-[min(1180px,calc(100%-2rem))]">
        <SectionHeading
          eyebrow="The journey feeling"
          title="The site should feel like moving through scenes, not scrolling through blocks."
          description="Every section should create a new moment: reveal, contrast, motion, atmosphere, payoff. The trick is to make that feel smooth and premium — not like the GPU is fighting for its life."
        />
      </div>
    </section>

    <section id="strengths" class="pb-12 pt-6 md:pb-20">
      <div class="mx-auto grid w-[min(1180px,calc(100%-1.5rem))] gap-5 md:w-[min(1180px,calc(100%-2rem))] md:grid-cols-3">
        {featuredProjects.map((item, index) => (
          <article class="panel card-hover rounded-[30px] p-6">
            <p class="text-xs font-semibold uppercase tracking-[0.22em] text-brand-aqua/75">0{index + 1}</p>
            <h3 class="mt-3 text-2xl font-semibold text-white">{item.title}</h3>
            <p class="mt-4 text-sm leading-7 text-brand-muted">{item.description}</p>
            <div class="mt-6 flex flex-wrap gap-2">
              {item.tags.map((tag) => (
                <span class="rounded-full border border-white/10 bg-white/5 px-3 py-1 text-xs text-white/75">{tag}</span>
              ))}
            </div>
          </article>
        ))}
      </div>
    </section>

    <section id="projects" class="pb-12 pt-4 md:pb-20">
      <div class="mx-auto w-[min(1180px,calc(100%-1.5rem))] md:w-[min(1180px,calc(100%-2rem))]">
        <div class="panel rounded-[36px] p-6 md:p-8">
          <SectionHeading
            eyebrow="Foundation preview"
            title="This is the baseline shell. The next layers are projects, blog, and full case-study routes."
            description="We are moving from a single static page into a true frontend application. The build will expand into project catalogs, project detail pages, article pages, and more immersive motion with the same speed-first mindset."
          />

          <div class="mt-8 grid gap-4 md:grid-cols-2">
            <div class="rounded-[28px] border border-white/10 bg-white/5 p-5">
              <p class="text-sm font-semibold text-white">Planned routes</p>
              <ul class="mt-4 space-y-3 text-sm text-brand-muted">
                <li>/ — cinematic homepage</li>
                <li>/projects — curated work shelf</li>
                <li>/projects/[slug] — case-study detail pages</li>
                <li>/blog — article index</li>
                <li>/blog/[slug] — writing detail pages</li>
                <li>/about — professional story and values</li>
              </ul>
            </div>
            <div class="rounded-[28px] border border-white/10 bg-white/5 p-5">
              <p class="text-sm font-semibold text-white">Motion principles</p>
              <ul class="mt-4 space-y-3 text-sm text-brand-muted">
                <li>Hero depth without heavy JS</li>
                <li>Scene-based section reveals</li>
                <li>Hover and transition polish that feels expensive</li>
                <li>Reduced-motion safety built in</li>
                <li>Performance wins over gimmicks</li>
              </ul>
            </div>
          </div>
        </div>
      </div>
    </section>

    <section id="writing" class="pb-16 pt-4 md:pb-24">
      <div class="mx-auto w-[min(1180px,calc(100%-1.5rem))] md:w-[min(1180px,calc(100%-2rem))]">
        <div class="grid gap-5 md:grid-cols-[0.95fr_1.05fr]">
          <div class="panel rounded-[32px] p-6 md:p-8">
            <SectionHeading
              eyebrow="Writing signal"
              title="The blog layer won’t be filler. It already has real engineering material behind it."
              description="The portfolio should show not only what Mahfuz builds, but how he thinks. DEV articles give us a strong starting lane for the future blog section and credibility storytelling."
            />
          </div>

          <div class="space-y-4">
            {articleHighlights.map((article) => (
              <article class="panel card-hover rounded-[28px] p-5">
                <p class="text-xs font-semibold uppercase tracking-[0.2em] text-brand-pink/75">Engineering note</p>
                <h3 class="mt-3 text-xl font-semibold text-white">{article}</h3>
                <p class="mt-2 text-sm leading-7 text-brand-muted">Technical writing around Laravel, async jobs, search, deployment, and backend behavior — useful for visitors who want substance, not just glossy visuals.</p>
              </article>
            ))}
          </div>
        </div>
      </div>
    </section>
  </main>
</Layout>
