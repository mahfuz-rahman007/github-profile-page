---
import Layout from '../layouts/Layout.astro';
import Nav from '../components/Nav.astro';
import SectionHeading from '../components/SectionHeading.astro';

const focusPillars = [
  {
    id: '01',
    title: 'Systems that survive real users',
    description: 'Production-focused engineering across backend behavior, product delivery, performance, and the kind of edge cases that visit around 2 AM.',
    tags: ['Laravel', 'Nuxt / Vue', 'Product delivery'],
  },
  {
    id: '02',
    title: 'Frontend polish with operator discipline',
    description: 'Interfaces should feel premium, intentional, and smooth — not overloaded with motion that murders performance for no reason.',
    tags: ['React', 'Tailwind', 'Interaction design'],
  },
  {
    id: '03',
    title: 'Infrastructure-aware execution',
    description: 'VPS workflows, Dockerized services, CI/CD, zero-downtime deployment, and backend architecture that still behaves after launch.',
    tags: ['Docker', 'GitHub Actions', 'AWS / VPS'],
  },
];

const sceneMoments = [
  {
    label: 'Scene 01',
    title: 'Enter with atmosphere',
    text: 'A hero that feels cinematic, responsive, and modern — enough motion to feel alive, never enough to slow the first impression.',
  },
  {
    label: 'Scene 02',
    title: 'Move through proof',
    text: 'Projects, writing, and capabilities should appear like discoveries in the journey, not like random blocks stacked for compliance.',
  },
  {
    label: 'Scene 03',
    title: 'Leave with recall',
    text: 'The final effect should be memorable: visitors understand the engineering depth, feel the taste level, and remember the experience later.',
  },
];

const projects = [
  {
    title: 'xCloud engineering',
    summary: 'Feature delivery, product behavior, and implementation work inside a real cloud platform context.',
    detail: 'Practical engineering focused on shipping, iteration, and maintainability.',
    stack: 'Laravel · Vue / Nuxt · MySQL · Redis',
    accent: 'from-brand-accent/40 via-brand-accent/10 to-transparent',
  },
  {
    title: 'News & content platforms',
    summary: 'Newspaper/blogging products, content-heavy systems, and architecture decisions that care about speed and scale.',
    detail: 'Where backend structure and frontend delivery both matter at once.',
    stack: 'Laravel · Nuxt · Search · Caching',
    accent: 'from-brand-pink/35 via-brand-pink/10 to-transparent',
  },
  {
    title: 'Deployment-aware builds',
    summary: 'Applications shaped around CI/CD, containerization, VPS delivery, and operational calm after launch.',
    detail: 'The kind of work that makes polished demos survive contact with production.',
    stack: 'Docker · GitHub Actions · AWS · Nginx',
    accent: 'from-brand-aqua/35 via-brand-aqua/10 to-transparent',
  },
];

const writingHighlights = [
  {
    title: 'PHP is a Single-Threaded Language, So How Does Laravel Handle Queue Jobs Asynchronously?',
    meta: 'Laravel · PHP · Queues',
  },
  {
    title: 'Exploring MySQL Full-Text Search and Its Implementation in Laravel',
    meta: 'MySQL · Laravel · Search',
  },
  {
    title: 'Docker Multi-Container Deployment with GitHub Actions in Laravel',
    meta: 'Docker · CI/CD · Deployment',
  },
];

const marqueeItems = [
  'Laravel',
  'React',
  'Vue',
  'Nuxt',
  'TypeScript',
  'Node',
  'Docker',
  'AWS',
  'Redis',
  'PostgreSQL',
  'System Design',
  'GitHub Actions',
];

const marqueeLoop = [...marqueeItems, ...marqueeItems];
---

<Layout>
  <a id="top"></a>
  <Nav />

  <main>
    <section class="relative overflow-hidden pb-18 pt-8 md:pb-28 md:pt-12">
      <div class="noise"></div>
      <div class="hero-orb orb-a"></div>
      <div class="hero-orb orb-b"></div>
      <div class="hero-orb orb-c"></div>

      <div class="mx-auto grid w-[min(1180px,calc(100%-1.5rem))] gap-6 md:w-[min(1180px,calc(100%-2rem))] md:grid-cols-[1.2fr_0.8fr] md:items-stretch">
        <div class="panel glass-line section-glow relative overflow-hidden rounded-[34px] p-7 md:p-10">
          <div class="absolute inset-0 bg-[radial-gradient(circle_at_top_right,rgba(124,156,255,0.18),transparent_30%),radial-gradient(circle_at_bottom_left,rgba(111,255,233,0.08),transparent_24%)]"></div>
          <div class="relative z-10">
            <p class="eyebrow mb-5 text-xs font-semibold text-brand-aqua/80">Full-stack engineer • systems-minded builder • product taste</p>
            <h1 class="max-w-4xl text-5xl font-semibold tracking-[-0.075em] text-white md:text-7xl md:leading-[0.92]">
              Build a portfolio that feels less like a page and more like a guided scene-by-scene experience.
            </h1>
            <p class="mt-6 max-w-2xl text-base leading-8 text-brand-muted md:text-lg">
              Mahfuzur Rahman builds practical systems, polished interfaces, and production-grade experiences. This portfolio is becoming an immersive frontend application — fast, cinematic, and smooth enough that each section feels like a new chapter.
            </p>

            <div class="mt-8 flex flex-wrap gap-3">
              <a href="#projects" class="shine rounded-full bg-white px-5 py-3 text-sm font-semibold text-slate-950 transition hover:translate-y-[-1px]">See the project journey</a>
              <a href="#writing" class="rounded-full border border-white/10 bg-white/5 px-5 py-3 text-sm font-medium text-white/85 transition hover:border-white/25 hover:bg-white/8">Read engineering notes</a>
            </div>

            <div class="mt-10 grid gap-4 sm:grid-cols-3">
              <div class="metric-glow rounded-[28px] border border-white/10 bg-white/5 p-4">
                <p class="text-3xl font-semibold text-white">16+</p>
                <p class="mt-2 text-sm text-brand-muted">Published DEV posts turning system work into readable engineering insight.</p>
              </div>
              <div class="metric-glow rounded-[28px] border border-white/10 bg-white/5 p-4">
                <p class="text-3xl font-semibold text-white">Full-stack</p>
                <p class="mt-2 text-sm text-brand-muted">Laravel, React, Vue, Nuxt, Node, Docker, AWS, Redis, PostgreSQL and more.</p>
              </div>
              <div class="metric-glow rounded-[28px] border border-white/10 bg-white/5 p-4">
                <p class="text-3xl font-semibold text-white">Fast-first</p>
                <p class="mt-2 text-sm text-brand-muted">Premium motion, but only the kind that respects performance and attention.</p>
              </div>
            </div>
          </div>
        </div>

        <aside class="panel rounded-[34px] p-6 md:p-8">
          <div class="flex h-full flex-col justify-between gap-6">
            <div>
              <p class="eyebrow text-xs font-semibold text-brand-pink/80">Journey preview</p>
              <h2 class="mt-3 text-2xl font-semibold text-white md:text-3xl">A smoother, deeper portfolio is now the mission.</h2>
            </div>

            <div class="story-line space-y-5 rounded-[28px] border border-white/10 bg-white/5 p-5">
              {sceneMoments.map((step) => (
                <div class="relative pl-8">
                  <span class="absolute left-[0.3rem] top-1 h-3 w-3 rounded-full bg-brand-accent shadow-[0_0_24px_rgba(124,156,255,0.9)]"></span>
                  <p class="text-xs font-semibold uppercase tracking-[0.2em] text-brand-aqua/80">{step.label}</p>
                  <h3 class="mt-1 text-lg font-semibold text-white">{step.title}</h3>
                  <p class="mt-2 text-sm leading-7 text-brand-muted">{step.text}</p>
                </div>
              ))}
            </div>

            <div class="terminal-card rounded-[28px] border border-white/10 p-5">
              <div class="mb-4 flex gap-2">
                <span class="h-2.5 w-2.5 rounded-full bg-brand-pink/90"></span>
                <span class="h-2.5 w-2.5 rounded-full bg-brand-gold/90"></span>
                <span class="h-2.5 w-2.5 rounded-full bg-brand-aqua/90"></span>
              </div>
              <p class="font-[Geist_Mono] text-xs uppercase tracking-[0.22em] text-white/50">Current focus</p>
              <p class="mt-3 text-sm leading-7 text-brand-muted">Astro foundation, scene-based art direction, project/blog architecture, GitHub Pages-safe deployment, and a homepage that makes visitors stay instead of politely escaping.</p>
            </div>
          </div>
        </aside>
      </div>
    </section>

    <section id="journey" class="section-fade relative pb-14 pt-8 md:pb-20">
      <div class="scene-band py-14 md:py-18">
        <div class="mx-auto grid w-[min(1180px,calc(100%-1.5rem))] gap-10 md:w-[min(1180px,calc(100%-2rem))] md:grid-cols-[0.9fr_1.1fr] md:items-end">
          <div>
            <p class="eyebrow mb-4 text-xs font-semibold text-brand-aqua/80">The journey feeling</p>
            <h2 class="text-4xl font-semibold tracking-[-0.05em] text-white md:text-6xl md:leading-[0.95]">
              The user should feel like they’re moving through scenes, not scrolling through blocks.
            </h2>
          </div>
          <div class="story-rail pl-6 text-base leading-8 text-brand-muted md:pl-10">
            <p>
              Every section should create a new moment: reveal, contrast, motion, atmosphere, payoff.
            </p>
            <p class="mt-4 text-white/78">
              Strong transitions, cleaner pacing, and a couple of memorable set pieces will make the experience feel new without sacrificing speed.
            </p>
          </div>
        </div>
      </div>
    </section>

    <section class="pb-6 pt-2">
      <div class="mx-auto w-[min(1180px,calc(100%-1.5rem))] md:w-[min(1180px,calc(100%-2rem))]">
        <div class="marquee-glow rounded-full border border-white/10 bg-white/5 px-4 py-3 backdrop-blur-xl">
          <div class="marquee-track text-sm font-medium text-white/72">
            {marqueeLoop.map((item) => (
              <div class="flex items-center gap-4 rounded-full border border-white/8 bg-white/5 px-4 py-2 whitespace-nowrap">
                <span class="h-1.5 w-1.5 rounded-full bg-brand-accent"></span>
                <span>{item}</span>
              </div>
            ))}
          </div>
        </div>
      </div>
    </section>

    <section class="pb-16 pt-10 md:pb-24">
      <div class="mx-auto w-[min(1180px,calc(100%-1.5rem))] md:w-[min(1180px,calc(100%-2rem))]">
        <div class="signal-core panel relative overflow-hidden rounded-[38px] px-6 py-10 md:px-10 md:py-14">
          <div class="noise"></div>
          <div class="relative z-10 mx-auto max-w-4xl text-center">
            <p class="eyebrow mb-4 text-xs font-semibold text-brand-gold/80">Signature moment</p>
            <h2 class="text-4xl font-semibold tracking-[-0.06em] text-white md:text-6xl md:leading-[0.94]">
              Smooth enough to feel effortless. Strange enough to feel fresh.
            </h2>
            <p class="mx-auto mt-5 max-w-2xl text-base leading-8 text-brand-muted md:text-lg">
              The experience should feel like engineering, atmosphere, and motion all agreed to behave. Not chaos. Not a template. A controlled kind of wow.
            </p>

            <div class="mt-8 flex flex-wrap items-center justify-center gap-3">
              <span class="signal-chip rounded-full border border-white/10 bg-white/6 px-4 py-2 text-sm text-white/82">Scene transitions</span>
              <span class="signal-chip rounded-full border border-white/10 bg-white/6 px-4 py-2 text-sm text-white/82">Depth without bloat</span>
              <span class="signal-chip rounded-full border border-white/10 bg-white/6 px-4 py-2 text-sm text-white/82">Fast first impression</span>
              <span class="signal-chip rounded-full border border-white/10 bg-white/6 px-4 py-2 text-sm text-white/82">Memorable product feel</span>
            </div>
          </div>
        </div>
      </div>
    </section>

    <section id="strengths" class="pb-16 pt-2 md:pb-24">
      <div class="mx-auto w-[min(1180px,calc(100%-1.5rem))] md:w-[min(1180px,calc(100%-2rem))]">
        <div class="grid gap-5 md:grid-cols-[1.05fr_0.95fr]">
          <article class="panel glass-line relative overflow-hidden rounded-[34px] p-6 md:p-8">
            <div class="absolute inset-0 bg-[radial-gradient(circle_at_top_left,rgba(124,156,255,0.16),transparent_30%),linear-gradient(135deg,rgba(255,255,255,0.02),rgba(255,255,255,0.01))]"></div>
            <div class="relative z-10">
              <p class="eyebrow mb-4 text-xs font-semibold text-brand-pink/80">Capability spotlight</p>
              <h2 class="max-w-2xl text-3xl font-semibold tracking-tight text-white md:text-5xl">A memorable portfolio needs both engineering proof and sensory polish.</h2>
              <p class="mt-5 max-w-2xl text-base leading-8 text-brand-muted">
                The point is not to cosplay as a designer or bury the work under effects. The point is to make the experience feel premium enough that the craftsmanship becomes obvious before the visitor even reads everything.
              </p>

              <div class="route-grid light-path mt-8 rounded-[30px] border border-white/10 p-5 md:p-6">
                <div class="grid gap-4 md:grid-cols-2">
                  <div class="rounded-[24px] border border-white/10 bg-slate-950/70 p-4">
                    <p class="font-[Geist_Mono] text-[11px] uppercase tracking-[0.24em] text-brand-aqua/80">Frontend feel</p>
                    <p class="mt-3 text-lg font-semibold text-white">Cinematic depth, clean hierarchy, motion with restraint.</p>
                  </div>
                  <div class="rounded-[24px] border border-white/10 bg-slate-950/70 p-4">
                    <p class="font-[Geist_Mono] text-[11px] uppercase tracking-[0.24em] text-brand-pink/80">Backend truth</p>
                    <p class="mt-3 text-lg font-semibold text-white">Real production systems, deployment experience, and implementation depth.</p>
                  </div>
                  <div class="rounded-[24px] border border-white/10 bg-slate-950/70 p-4 md:col-span-2">
                    <p class="font-[Geist_Mono] text-[11px] uppercase tracking-[0.24em] text-brand-accent/85">What visitors should feel</p>
                    <p class="mt-3 text-lg font-semibold text-white">"This is different" first. "This person is credible" immediately after.</p>
                  </div>
                </div>
              </div>
            </div>
          </article>

          <div class="grid gap-5">
            {focusPillars.map((item) => (
              <article class="panel card-hover rounded-[30px] p-6">
                <p class="text-xs font-semibold uppercase tracking-[0.22em] text-brand-aqua/75">{item.id}</p>
                <h3 class="mt-3 text-2xl font-semibold text-white">{item.title}</h3>
                <p class="mt-4 text-sm leading-7 text-brand-muted">{item.description}</p>
                <div class="mt-6 flex flex-wrap gap-2">
                  {item.tags.map((tag) => (
                    <span class="rounded-full border border-white/10 bg-white/5 px-3 py-1 text-xs text-white/75">{tag}</span>
                  ))}
                </div>
              </article>
            ))}
          </div>
        </div>
      </div>
    </section>

    <section id="projects" class="pb-16 pt-4 md:pb-24">
      <div class="mx-auto w-[min(1180px,calc(100%-1.5rem))] md:w-[min(1180px,calc(100%-2rem))]">
        <SectionHeading
          eyebrow="Project atmosphere"
          title="Featured work should feel like stepping into curated product rooms."
          description="The next layers will bring real case-study routes, but even the homepage should already hint at that feeling — depth, movement, precision, and enough visual storytelling to make people want to click further."
        />

        <div class="mt-8 grid gap-5 md:grid-cols-3">
          {projects.map((project) => (
            <article class="panel card-hover overflow-hidden rounded-[30px] p-5">
              <div class={`rounded-[24px] border border-white/10 bg-gradient-to-br ${project.accent} p-4`}>
                <div class="rounded-[22px] border border-white/10 bg-slate-950/72 p-4">
                  <div class="mb-6 flex items-center justify-between text-[11px] uppercase tracking-[0.24em] text-white/50">
                    <span>case-study seed</span>
                    <span>live direction</span>
                  </div>
                  <div class="space-y-3">
                    <div class="h-2.5 w-3/4 rounded-full bg-white/18"></div>
                    <div class="h-2.5 w-full rounded-full bg-white/10"></div>
                    <div class="h-2.5 w-5/6 rounded-full bg-white/10"></div>
                  </div>
                  <div class="mt-6 grid grid-cols-3 gap-3">
                    <div class="h-20 rounded-2xl border border-white/8 bg-white/6"></div>
                    <div class="h-20 rounded-2xl border border-white/8 bg-white/8"></div>
                    <div class="h-20 rounded-2xl border border-white/8 bg-white/6"></div>
                  </div>
                </div>
              </div>
              <h3 class="mt-5 text-2xl font-semibold text-white">{project.title}</h3>
              <p class="mt-3 text-sm leading-7 text-brand-muted">{project.summary}</p>
              <p class="mt-4 text-sm text-white/72">{project.detail}</p>
              <p class="mt-5 font-[Geist_Mono] text-[11px] uppercase tracking-[0.24em] text-brand-aqua/75">{project.stack}</p>
            </article>
          ))}
        </div>
      </div>
    </section>

    <section class="pb-16 pt-2 md:pb-24">
      <div class="mx-auto w-[min(1180px,calc(100%-1.5rem))] md:w-[min(1180px,calc(100%-2rem))]">
        <div class="panel grid gap-6 rounded-[36px] p-6 md:grid-cols-[0.9fr_1.1fr] md:p-8">
          <div>
            <p class="eyebrow mb-4 text-xs font-semibold text-brand-gold/80">Foundation preview</p>
            <h2 class="text-3xl font-semibold tracking-tight text-white md:text-5xl">This is no longer a static profile page pretending to be enough.</h2>
            <p class="mt-5 text-base leading-8 text-brand-muted">
              We are rebuilding this into a true frontend application with stronger pacing, route depth, case studies, and blog detail pages — while keeping the speed and deployment story clean.
            </p>
          </div>

          <div class="grid gap-4 md:grid-cols-2">
            <div class="rounded-[28px] border border-white/10 bg-white/5 p-5">
              <p class="text-sm font-semibold text-white">Planned routes</p>
              <ul class="mt-4 space-y-3 text-sm leading-7 text-brand-muted">
                <li>/ — cinematic homepage</li>
                <li>/projects — curated work shelf</li>
                <li>/projects/[slug] — case-study detail pages</li>
                <li>/blog — article index</li>
                <li>/blog/[slug] — writing detail pages</li>
                <li>/about — professional story and values</li>
              </ul>
            </div>
            <div class="rounded-[28px] border border-white/10 bg-white/5 p-5">
              <p class="text-sm font-semibold text-white">Motion principles</p>
              <ul class="mt-4 space-y-3 text-sm leading-7 text-brand-muted">
                <li>Hero depth without heavy JS</li>
                <li>Scene-based transitions that feel intentional</li>
                <li>Hover polish that feels expensive</li>
                <li>Reduced-motion support built in</li>
                <li>Performance always wins over gimmicks</li>
              </ul>
            </div>
          </div>
        </div>
      </div>
    </section>

    <section id="writing" class="pb-18 pt-4 md:pb-28">
      <div class="mx-auto w-[min(1180px,calc(100%-1.5rem))] md:w-[min(1180px,calc(100%-2rem))]">
        <div class="grid gap-5 md:grid-cols-[0.9fr_1.1fr]">
          <div class="panel rounded-[32px] p-6 md:p-8">
            <SectionHeading
              eyebrow="Writing signal"
              title="The writing layer gives the portfolio something a lot of flashy sites never earn: substance."
              description="DEV articles already show a real pattern — Laravel internals, MySQL search, deployment flow, backend behavior. That means the future blog section can be credible from day one, not decorative filler." 
            />
          </div>

          <div class="space-y-4">
            {writingHighlights.map((article, index) => (
              <article class="panel card-hover rounded-[28px] p-5">
                <div class="flex items-start gap-4">
                  <div class="flex h-12 w-12 shrink-0 items-center justify-center rounded-2xl border border-white/10 bg-white/5 text-sm font-semibold text-white/80">
                    0{index + 1}
                  </div>
                  <div>
                    <p class="text-xs font-semibold uppercase tracking-[0.2em] text-brand-pink/75">Engineering note</p>
                    <h3 class="mt-2 text-xl font-semibold text-white">{article.title}</h3>
                    <p class="mt-3 font-[Geist_Mono] text-[11px] uppercase tracking-[0.24em] text-brand-aqua/75">{article.meta}</p>
                    <p class="mt-3 text-sm leading-7 text-brand-muted">Useful writing for visitors who want proof of thinking, not just a polished landing page with suspicious levels of confidence.</p>
                  </div>
                </div>
              </article>
            ))}
          </div>
        </div>
      </div>
    </section>
  </main>
</Layout>
