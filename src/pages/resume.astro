---
import Layout from '../layouts/Layout.astro';
import Nav from '../components/Nav.astro';
import Footer from '../components/Footer.astro';
import PageHero from '../components/PageHero.astro';
import { profile } from '../data/profile';
---

<Layout title="Resume — Mahfuzur Rahman" description="Resume snapshot for Mahfuzur Rahman.">
  <Nav />
  <main class="pb-18 pt-8 md:pb-28 md:pt-12">
    <div class="mx-auto w-[min(980px,calc(100%-1.5rem))] space-y-8 md:w-[min(980px,calc(100%-2rem))]">
      <PageHero eyebrow="Resume" title="Quick resume snapshot" description="A lightweight web version of the key resume facts behind the portfolio." />
      <section class="panel rounded-[32px] p-6 md:p-8">
        <h2 class="text-2xl font-semibold text-white">Summary</h2>
        <p class="mt-4 text-base leading-8 text-brand-muted">{profile.intro}</p>
      </section>
      <section class="panel rounded-[32px] p-6 md:p-8">
        <h2 class="text-2xl font-semibold text-white">Experience</h2>
        <div class="mt-6 space-y-5">
          {profile.experience.map((item) => (
            <div class="rounded-[24px] border border-white/10 bg-white/5 p-4">
              <h3 class="text-lg font-semibold text-white">{item.role} · {item.company}</h3>
              <p class="mt-1 text-sm text-brand-muted">{item.period}</p>
            </div>
          ))}
        </div>
      </section>
      <section class="panel rounded-[32px] p-6 md:p-8">
        <h2 class="text-2xl font-semibold text-white">Contact</h2>
        <a href={`mailto:${profile.email}`} class="mt-4 inline-block text-lg text-white transition hover:text-brand-aqua">{profile.email}</a>
      </section>
    </div>
  </main>
  <Footer />
</Layout>
