---
import '../styles/global.css';

interface Props {
  title?: string;
  description?: string;
}

const {
  title = 'Mahfuzur Rahman — Full-Stack Engineer',
  description = 'Premium portfolio experience for Mahfuzur Rahman — full-stack engineer building polished products, scalable systems, and memorable interfaces.',
} = Astro.props;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="generator" content={Astro.generator} />
    <meta name="description" content={description} />
    <meta name="theme-color" content="#040611" />
    <link rel="canonical" href={new URL(Astro.url.pathname, Astro.site)} />
    <title>{title}</title>
  </head>
  <body>
    <slot />
  </body>
</html>
