---
import { profile } from '../data/profile';
---

<div class="panel rounded-[30px] p-5 md:p-6">
  <p class="eyebrow mb-4 text-xs font-semibold text-brand-gold/80">Contact</p>
  <h3 class="text-2xl font-semibold text-white">Let’s build something useful.</h3>
  <p class="mt-4 text-sm leading-7 text-brand-muted">
    If you have a product idea, engineering problem, or full-stack build that needs someone who can think from architecture down to delivery details, send an email.
  </p>

  <div class="mt-6 space-y-3 text-sm text-white/80">
    <a href={`mailto:${profile.email}`} class="flex items-center justify-between rounded-2xl border border-white/10 bg-white/5 px-4 py-3 transition hover:border-white/20 hover:text-white">
      <span>{profile.email}</span>
      <span aria-hidden="true">↗</span>
    </a>
    <a href={profile.github} target="_blank" rel="noreferrer" class="flex items-center justify-between rounded-2xl border border-white/10 bg-white/5 px-4 py-3 transition hover:border-white/20 hover:text-white">
      <span>GitHub profile</span>
      <span aria-hidden="true">↗</span>
    </a>
    <a href={profile.linkedin} target="_blank" rel="noreferrer" class="flex items-center justify-between rounded-2xl border border-white/10 bg-white/5 px-4 py-3 transition hover:border-white/20 hover:text-white">
      <span>LinkedIn</span>
      <span aria-hidden="true">↗</span>
    </a>
  </div>
</div>
