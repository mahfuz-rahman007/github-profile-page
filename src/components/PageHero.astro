---
interface Props {
  title: string;
  description?: string;
  align?: 'left' | 'center';
  eyebrow?: string;
  center?: boolean;
}

const { eyebrow, title, description, align = 'left', center = false } = Astro.props;
const wrapClass = align === 'center' || center ? 'mx-auto max-w-4xl text-center' : 'max-w-4xl';
---

<div class={wrapClass}>
  {eyebrow && <p class="eyebrow mb-4 text-xs font-semibold text-brand-aqua/80">{eyebrow}</p>}
  <h1 class="text-4xl font-semibold tracking-[-0.06em] text-white md:text-6xl md:leading-[0.95]">{title}</h1>
  {description && <p class="mt-5 text-base leading-8 text-brand-muted md:text-lg">{description}</p>}
</div>
