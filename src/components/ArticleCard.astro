---
import type { Article } from '../data/articles';

interface Props {
  article: Article;
}

const { article } = Astro.props;
---

<article class="panel card-hover rounded-[28px] p-5">
  <p class="text-xs font-semibold uppercase tracking-[0.2em] text-brand-pink/75">{article.topic}</p>
  <h3 class="mt-3 text-xl font-semibold text-white">{article.title}</h3>
  <p class="mt-3 text-sm leading-7 text-brand-muted">{article.summary}</p>
  <div class="mt-5 flex flex-wrap items-center gap-3 text-xs text-white/55">
    <span>{article.date}</span>
    <span>•</span>
    <span>{article.readTime}</span>
  </div>
  <a href={`/writing/${article.slug}`} class="mt-5 inline-flex items-center gap-2 text-sm font-semibold text-white transition hover:text-brand-aqua">
    Read summary
    <span aria-hidden="true">→</span>
  </a>
</article>
