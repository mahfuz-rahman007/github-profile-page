---
import type { SocialLink } from '../data/profile';

interface Props {
  links: SocialLink[];
  variant?: 'default' | 'compact';
}

const { links, variant = 'default' } = Astro.props;

const iconClass = variant === 'compact' ? 'h-4 w-4' : 'h-5 w-5';
const itemClass =
  variant === 'compact'
    ? 'inline-flex items-center gap-2 rounded-full border border-white/10 bg-white/6 px-3 py-2 text-sm text-white/82 transition hover:border-white/20 hover:text-white'
    : 'inline-flex items-center gap-3 rounded-full border border-white/10 bg-white/6 px-4 py-3 text-sm text-white/82 transition hover:border-white/20 hover:text-white';

const renderIcon = (icon: SocialLink['icon']) => {
  switch (icon) {
    case 'github':
      return `<svg viewBox="0 0 24 24" fill="currentColor" class="${iconClass}"><path d="M12 .5C5.648.5.5 5.648.5 12A11.5 11.5 0 0 0 8.36 22.06c.6.11.82-.26.82-.58v-2.03c-3.24.7-3.92-1.56-3.92-1.56-.52-1.34-1.3-1.69-1.3-1.69-1.07-.73.08-.71.08-.71 1.18.08 1.8 1.2 1.8 1.2 1.05 1.8 2.75 1.28 3.42.98.11-.76.41-1.28.74-1.58-2.58-.29-5.29-1.29-5.29-5.73 0-1.27.45-2.3 1.2-3.12-.13-.29-.53-1.47.11-3.06 0 0 .97-.31 3.18 1.19a10.9 10.9 0 0 1 5.78 0c2.2-1.5 3.17-1.19 3.17-1.19.64 1.59.24 2.77.11 3.06.74.82 1.2 1.85 1.2 3.12 0 4.45-2.71 5.44-5.3 5.73.42.36.79 1.06.79 2.14v3.17c0 .32.22.7.82.58A11.5 11.5 0 0 0 23.5 12C23.5 5.648 18.352.5 12 .5Z"/></svg>`;
    case 'linkedin':
      return `<svg viewBox="0 0 24 24" fill="currentColor" class="${iconClass}"><path d="M4.98 3.5C4.98 4.88 3.86 6 2.49 6S0 4.88 0 3.5 1.11 1 2.49 1s2.49 1.12 2.49 2.5ZM.5 8h4V23h-4V8Zm7 0h3.82v2.05h.05c.53-1 1.84-2.05 3.79-2.05 4.05 0 4.8 2.66 4.8 6.12V23h-4v-6.95c0-1.66-.03-3.8-2.32-3.8-2.32 0-2.67 1.81-2.67 3.68V23h-4V8Z"/></svg>`;
    case 'dev':
      return `<svg viewBox="0 0 24 24" fill="currentColor" class="${iconClass}"><path d="M7.83 10.5h-1.2v3h1.2c1.03 0 1.67-.58 1.67-1.5s-.64-1.5-1.67-1.5Zm8.58.03h-1.35v2.95h1.32c1.1 0 1.79-.56 1.79-1.47 0-.92-.69-1.48-1.76-1.48ZM22 0H2C.9 0 0 .9 0 2v20c0 1.1.9 2 2 2h20c1.1 0 2-.9 2-2V2c0-1.1-.9-2-2-2ZM5.21 16.88H3.28V8.98h1.93c2.55 0 3.98 1.43 3.98 3.95s-1.43 3.95-3.98 3.95Zm5.43 0H8.72V8.98h1.92v7.9Zm6.02-6.35h-2.44v1.58h2.22v1.54h-2.22v3.23h-1.93V8.98h4.37v1.55Zm-.21 6.35h-3.37V8.98h3.37c2.57 0 4.07 1.41 4.07 3.95s-1.5 3.95-4.07 3.95Z"/></svg>`;
    case 'mail':
      return `<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" class="${iconClass}"><path d="M4 6h16v12H4z"/><path d="m4 8 8 6 8-6"/></svg>`;
  }
};
---

<div class="flex flex-wrap gap-3">
  {links.map((link) => (
    <a href={link.href} target={link.href.startsWith('mailto:') ? undefined : '_blank'} rel={link.href.startsWith('mailto:') ? undefined : 'noreferrer'} class={itemClass}>
      <Fragment set:html={renderIcon(link.icon)} />
      <span>{link.label}</span>
    </a>
  ))}
</div>
