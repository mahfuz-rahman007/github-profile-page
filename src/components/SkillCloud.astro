---
interface Props {
  groups: { title: string; items: string[] }[];
}

const { groups } = Astro.props;
const allItems = groups.flatMap((group) => group.items);
---

<div class="panel rounded-[32px] p-6 md:p-8">
  <div class="flex flex-wrap items-start gap-4">
    {allItems.map((item, index) => (
      <button
        type="button"
        class:list={[
          'skill-badge rounded-full border border-white/10 bg-white/6 px-4 py-2 text-sm text-white/82 transition hover:border-white/20 hover:text-white',
          index % 3 === 0 && 'translate-y-0 md:-translate-y-1',
          index % 4 === 0 && 'md:translate-y-2',
        ]}
        style={`animation-delay:${(index % 6) * 0.35}s`}
      >
        {item}
      </button>
    ))}
  </div>
</div>
