---
import type { Project } from '../data/projects';

interface Props {
  project: Project;
  compact?: boolean;
}

const { project, compact = false } = Astro.props;
const toneMap = {
  accent: 'from-brand-accent/35 via-brand-accent/10 to-transparent',
  pink: 'from-brand-pink/35 via-brand-pink/10 to-transparent',
  aqua: 'from-brand-aqua/35 via-brand-aqua/10 to-transparent',
  gold: 'from-brand-gold/35 via-brand-gold/10 to-transparent',
} as const;
---

<article class="panel card-hover overflow-hidden rounded-[30px] p-5">
  <div class={`rounded-[24px] border border-white/10 bg-gradient-to-br ${toneMap[project.heroTone]} p-4`}>
    <div class="rounded-[22px] border border-white/10 bg-slate-950/72 p-4">
      <div class="mb-6 flex items-center justify-between text-[11px] uppercase tracking-[0.24em] text-white/50">
        <span>{project.category}</span>
        <span>{project.period}</span>
      </div>
      <div class="space-y-3">
        <div class="h-2.5 w-2/3 rounded-full bg-white/18"></div>
        <div class="h-2.5 w-full rounded-full bg-white/10"></div>
        <div class="h-2.5 w-5/6 rounded-full bg-white/10"></div>
      </div>
      <div class="mt-6 grid grid-cols-3 gap-3">
        <div class="h-18 rounded-2xl border border-white/8 bg-white/6"></div>
        <div class="h-18 rounded-2xl border border-white/8 bg-white/8"></div>
        <div class="h-18 rounded-2xl border border-white/8 bg-white/6"></div>
      </div>
    </div>
  </div>
  <h3 class="mt-5 text-2xl font-semibold text-white">{project.title}</h3>
  <p class="mt-3 text-sm leading-7 text-brand-muted">{project.tagline}</p>
  {!compact && <p class="mt-4 text-sm text-white/78">{project.impact}</p>}
  <div class="mt-5 flex flex-wrap gap-2">
    {project.stack.slice(0, compact ? 3 : 5).map((item) => (
      <span class="rounded-full border border-white/10 bg-white/5 px-3 py-1 text-xs text-white/75">{item}</span>
    ))}
  </div>
  <a href={`/projects/${project.slug}`} class="mt-6 inline-flex items-center gap-2 text-sm font-semibold text-white transition hover:text-brand-aqua">
    View case study
    <span aria-hidden="true">→</span>
  </a>
</article>
