---
import type { GalleryImage } from '../data/gallery';

interface Props {
  image: GalleryImage;
}

const { image } = Astro.props;
const ratioClass = {
  portrait: 'aspect-[4/5]',
  square: 'aspect-square',
  landscape: 'aspect-[4/3]',
  wide: 'aspect-[16/9]',
}[image.ratio];
---

<figure class="panel card-hover overflow-hidden rounded-[28px] p-3">
  <div class:list={['overflow-hidden rounded-[22px] border border-white/10 bg-slate-950/70', ratioClass]}>
    <img src={image.src} alt={image.title} class="h-full w-full object-cover" loading="lazy" />
  </div>
  <figcaption class="px-2 pb-2 pt-4">
    <h3 class="text-lg font-semibold text-white">{image.title}</h3>
    <p class="mt-2 text-sm leading-7 text-brand-muted">{image.caption}</p>
  </figcaption>
</figure>
